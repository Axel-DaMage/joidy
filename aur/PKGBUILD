# Maintainer: Joidy App <https://github.com/Axel-DaMage/joidy>
pkgname=joidy
pkgver=1.0.0
pkgrel=1
pkgdesc="Personal knowledge management with gamification"
arch=('any')
url="https://joidy-web.vercel.app"
license=('GPL3')
depends=('docker' 'docker-compose')
makedepends=('git')
source=("${url}/archive/v${pkgver}.tar.gz")
sha256sums=('SKIP')

package() {
  install -Dm755 "${srcdir}/joidy/bin/joidy" "${pkgdir}/usr/bin/joidy"
  install -Dm644 "${srcdir}/joidy/docker-compose.yml" "${pkgdir}/usr/share/joidy/docker-compose.yml"
  install -Dm644 "${srcdir}/joidy/.env.example" "${pkgdir}/usr/share/joidy/.env.example"
}
